{
  "expo": {
    "name": "ControlAsistencia",
    "slug": "controlasistencia-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "controlasistencia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.controlasistencia.pro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.controlasistencia.pro",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://controlasistencia.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ControlAsistencia necesita acceso a tu ubicación para validar que estás en el punto de trabajo."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ControlAsistencia necesita acceso a tus fotos para adjuntar boletas a los gastos.",
          "cameraPermission": "ControlAsistencia necesita acceso a la cámara para fotografiar boletas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://controlasistencia.app"
      },
      "eas": {
        "projectId": "9b0baa3d-bd65-4931-804a-e47104e03f7b"
      }
    },
    "owner": "ncisternas"
  }
}
